        { label: 'Enterprise', tool: 'Attentive', reason: 'Acquisition at scale when custom pricing and managed services fit.' },
        { label: 'Bundled', tool: 'Omnisend', reason: 'Email + SMS + push for SMB teams needing one journey builder.' },
        { label: 'Data depth', tool: 'Klaviyo', reason: 'SMS credits with deep Shopify segmentation when profiles justify cost.' },
