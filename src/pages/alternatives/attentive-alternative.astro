        <ToolReview app={alternatives[3]} rank={4} paragraphs={['Omnisend SMB multichannel — acceptable when Attentive was overkill and prebuilt journeys beat black-box enterprise flows.']} />
        <ToolReview app={alternatives[4]} rank={5} paragraphs={['SMSBump if Yotpo stack already paid — evaluate modular vs Attentive single bill.']} />
        <ToolReview app={alternatives[5]} rank={6} paragraphs={['Sendlane guided retention for brands wanting human migration help post-Attentive without re-entering enterprise contracts.']} />
        <ToolReview app={alternatives[6]} rank={7} paragraphs={['Recart narrow cart SMS when Attentive broadcast programs were cost driver — strip to recovery-only.']} />
        <ToolReview app={alternatives[7]} rank={8} paragraphs={['Yotpo Email & SMS if reviews suite consolidation replaces Attentive breadth — audit module costs carefully.']} />
      </section>

