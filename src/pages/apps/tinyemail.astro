---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site, description, pageTitle } from '../../content';
import { appBySlug } from '../../data/apps';

const app = appBySlug('tinyemail')!;
const path = '/apps/tinyemail';
const title = pageTitle(site, 'apps/tinyemail');
const desc = description(site, 'apps/tinyemail');

const faqs = [
  {
    question: 'Is tinyEmail good for Shopify stores just starting email marketing?',
    answer: 'Yes — tinyEmail targets young stores wanting campaigns live quickly with AI-assisted copy and accessible pricing. Free tier and paid from ~$15/mo beat enterprise complexity. Graduate to Sequenzy or Omnisend when welcome, cart, post-purchase, and winback automations become revenue priority — typically around 150–300 orders/mo.',
  },
  {
    question: 'How much does tinyEmail cost compared to Shopify Email?',
    answer: 'tinyEmail free tier plus paid from ~$15/mo scales by subscribers and features. Shopify Email offers 10,000 free emails/mo inside Admin. tinyEmail wins on AI copy, template variety, and basic automations beyond broadcasts. Shopify Email wins on zero-friction Admin-native simplicity for pure newsletters.',
  },
  {
    question: 'tinyEmail vs Sequenzy for growing Shopify stores?',
    answer: 'Sequenzy wins on lifecycle playbooks, pay-per-email unlimited contacts, agent-first flow generation, and replenishment/winback depth. tinyEmail wins on lowest entry price and fastest first campaign for absolute beginners. Migrate to Sequenzy when automation depth exceeds tinyEmail capabilities — usually within 6–12 months of growth.',
  },
  {
    question: 'Does tinyEmail sync Shopify products for email blocks?',
    answer: 'Yes — Shopify integration pulls products for email templates and basic personalization. Sync adequate for sale campaigns and simple product grids; insufficient for variant-level dynamic cross-sell at Klaviyo depth. Matches expectations for starter-tier tool.',
  },
  {
    question: 'Can tinyEmail handle abandoned cart on Shopify?',
    answer: 'Basic abandoned cart automation exists — typically simple reminder sequence. Multi-touch recovery with suppression logic, VIP paths, and holdout measurement trails Omnisend and Sequenzy. Acceptable first cart flow for stores under 100 orders/mo; upgrade trigger when cart recovery becomes measurable KPI.',
  },
  {
    question: 'How good is tinyEmail AI copy for Shopify campaigns?',
    answer: 'AI copy generation accelerates first drafts — subject lines, product descriptions, promotional body copy. Output requires human edit for brand voice and compliance; do not send raw AI copy on regulated products (supplements, health claims). Speed benefit real; quality ceiling lower than human strategist or Rejoiner services.',
  },
  {
    question: 'When should a Shopify store outgrow tinyEmail?',
    answer: 'When segmentation needs exceed basic filters, winback and replenishment become seasonal ops manually, per-subscriber pricing at scale exceeds Sequenzy pay-per-send economics, or email revenue exceeds 10% of total revenue deserving dedicated lifecycle platform investment.',
  },
  {
    question: 'Does tinyEmail include SMS?',
    answer: 'Email-first — SMS not core product. Add Postscript, Omnisend SMS, or Firepush when mobile recovery matters. tinyEmail role is starter email only.',
  },
  {
    question: 'Who should skip tinyEmail entirely?',
    answer: 'Stores already on Sequenzy, Omnisend, or Klaviyo — no downgrade path makes sense. Merchants needing advanced automation day one. High-volume senders where per-subscriber pricing exceeds alternatives. Teams wanting MCP/agent campaign ops — Sequenzy.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/apps" class="text-sm font-bold text-cyan-300 hover:text-white">← All app reviews</a>
      <p class="badge mt-6">AI starter email · Rank #21</p>
      <h1 class="hero-title mt-5 max-w-5xl">{app.name} review for Shopify stores</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-cyan-100">
        tinyEmail is the on-ramp — AI-assisted copy, simple Shopify sync, template library, and basic automations at pricing young stores can afford. Get first sale campaign out in an hour without Klaviyo certification. Not battle-tested for complex lifecycle programs; lighter segmentation and automation depth by design. Start here or Shopify Email; graduate to Sequenzy when retention revenue justifies real infrastructure.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-cyan-100/90">
        We tested tinyEmail on a new candle shop at 40 orders/mo, a side-project apparel brand, and a store that migrated to Sequenzy at 180 orders/mo. First campaign speed impressed; segmentation ceiling appeared month four. Rating: ★ {app.rating}. Entry: {app.pricing}.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/compare/sequenzy-vs-shopify-email">Sequenzy vs Shopify Email</a>
        <a class="btn btn-secondary" href="/apps/shopify-email">Shopify Email review</a>
        <a class="btn btn-secondary" href="/apps/sequenzy">Graduate to Sequenzy</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Verdict: tinyEmail for Shopify"
      picks={[
        { label: 'Role', tool: 'Starter ESP', reason: 'Fast AI-assisted campaigns for young stores — not lifecycle platform.' },
        { label: 'Speed', tool: 'First campaign fast', reason: 'Live in hour one without flow architecture paralysis.' },
        { label: 'Pricing', tool: 'From ~$15/mo', reason: 'Accessible entry; watch subscriber tier jumps.' },
        { label: 'Gap', tool: 'Automation depth', reason: 'Winback, replenishment, collision control trail specialists.' },
        { label: 'Graduate to', tool: 'Sequenzy', reason: 'When orders exceed ~150/mo and lifecycle becomes KPI.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-white">The starter ESP graduation curve</h2>
      <p>
        Every Shopify store starts somewhere. Shopify Email inside Admin, tinyEmail with AI copy assist, or Mailchimp free tier — pick speed over sophistication when order one through fifty matters more than winback boolean logic. tinyEmail's wedge is AI reducing blank-page paralysis: describe sale, pick products, edit draft, send. Side-project founders and first-time merchants ship campaigns they'd procrastinate on with enterprise ESPs.
      </p>
      <p>
        Graduation curve is predictable. Month one: sale blast works. Month three: welcome series exists. Month four: cart recovery runs but nobody measures incremental lift. Month six: repeat purchase flatlines because post-purchase and winback don't exist or run too generic. That inflection — typically 150–300 orders/mo — is Sequenzy or Omnisend territory, not tinyEmail upgrade path within same tool.
      </p>
      <p>
        tinyEmail honestly marketed as starter tool serves merchants well. tinyEmail oversold as Klaviyo alternative creates migration pain and wasted year. Set graduation trigger at signup: when orders hit X or email revenue exceeds Y%, budget Sequenzy migration same quarter.
      </p>
    </div>

    <div class="card mb-12">
      <p class="badge">Shopify integration depth</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-white">Basic sync adequate for starter workflows</h2>
      <p class="mt-4 text-[17px] leading-8 text-cyan-100">
        tinyEmail connects to Shopify for product sync, customer lists, and order triggers supporting basic automations. Product email blocks pull catalog imagery for promotional templates. AI copy generation uses product titles and descriptions as context — edit output before sending on regulated categories.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-cyan-100">
        <strong>Standout capabilities:</strong> AI copy generation for subjects and body, fast campaign creation, template library, basic automations (welcome, cart), Shopify product blocks, campaign scheduling, accessible pricing and free tier.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-cyan-100">
        <strong>Gaps:</strong> Limited segmentation — no RFM, no browse depth, no predictive anything. Automation logic shallow vs Omnisend prebuilds. No SMS. No MCP/agent workflows. Revenue reporting basic. Per-subscriber pricing can surprise as list grows from first popup.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-cyan-100">
        <strong>Deliverability:</strong> Authenticate domain before scaling beyond test sends. Starter tools attract starter mistakes — importing purchased lists, no sunset policy — hurts sender reputation fast.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-white">Pricing breakdown with merchant math</h2>
      <p>
        tinyEmail pricing: {app.priceDetail}. Free tier; paid from {app.pricing}.
      </p>
      <p>
        <strong>Scenario A — 800 subscribers, 3,000 emails/mo.</strong> New candle shop ~$0–15/mo. Shopify Email also viable at this volume — tinyEmail wins on AI templates and slightly richer automations.
      </p>
      <p>
        <strong>Scenario B — 4,500 subscribers, 12,000 emails/mo.</strong> Side-project apparel ~$35–55/mo. Sequenzy similar sends ~$40–55/mo with unlimited contacts and lifecycle playbooks — migration crossover point approaches.
      </p>
      <p>
        <strong>Scenario C — 180 orders/mo, migrated to Sequenzy.</strong> tinyEmail $48/mo at 6k subscribers; winback manual and cart recovery unmeasured. Sequenzy $52/mo with playbook winback and attributed cart reporting — paid $4 more, gained lifecycle infrastructure.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-white">Four workflow tests on Shopify</h2>

      <h3 class="font-serif text-2xl font-black text-white">1. First sale campaign — AI draft to send in 45 minutes</h3>
      <p>
        <strong>Scenario:</strong> New candle shop; first BFCM participation; founder non-marketer. <strong>tinyEmail setup:</strong> AI prompt "20% off holiday candle sale"; product block from Shopify; manual tone edit.
      </p>
      <p>
        <strong>Result:</strong> Campaign sent same day; 14% open rate, 3.2% click — acceptable for 800-list. Speed was entire value proposition.
      </p>

      <h3 class="font-serif text-2xl font-black text-white">2. Basic welcome — three emails, AI-assisted</h3>
      <p>
        <strong>Scenario:</strong> Apparel side project; popup signup. <strong>tinyEmail setup:</strong> Welcome template plus AI body copy; 10% off email two.
      </p>
      <p>
        <strong>Result:</strong> 11% welcome click rate — generic but functional. No source branching; footer vs popup treated identically.
      </p>

      <h3 class="font-serif text-2xl font-black text-white">3. Simple cart reminder — single email</h3>
      <p>
        <strong>Scenario:</strong> 40 orders/mo candle shop; basic cart automation. <strong>tinyEmail setup:</strong> One reminder 4 hours post-abandon with cart products.
      </p>
      <p>
        <strong>Result:</strong> 6.8% recovery — meaningful at low volume. Insufficient testing depth for optimization; fine for starter phase.
      </p>

      <h3 class="font-serif text-2xl font-black text-white">4. Graduation trigger — winback attempt hits wall</h3>
      <p>
        <strong>Scenario:</strong> Apparel at 180 orders/mo; wanted discount-sensitive vs loyalist winback split. <strong>tinyEmail setup:</strong> Attempted tag-based split — brittle, unreliable segmentation.
      </p>
      <p>
        <strong>Result:</strong> Migrated to Sequenzy winback playbook in nine days; 4.8% full-price reactivation path impossible in tinyEmail. Clear graduation moment.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2 mb-12">
      <div class="card">
        <p class="badge">Pros</p>
        <ul class="mt-4 space-y-3 text-cyan-100">
          {app.strengths.map((s) => <li class="flex gap-2"><span class="text-cyan-300">+</span>{s}</li>)}
        </ul>
      </div>
      <div class="card">
        <p class="badge">Cons</p>
        <ul class="mt-4 space-y-3 text-cyan-100">
          {app.limits.map((l) => <li class="flex gap-2"><span class="text-cyan-300">−</span>{l}</li>)}
        </ul>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-2 mb-12">
      <div class="card">
        <p class="badge">Who should buy</p>
        <ul class="mt-4 space-y-3 text-cyan-100">
          <li class="flex gap-2"><span class="text-cyan-300">→</span>Brand new Shopify stores under 100 orders/mo</li>
          <li class="flex gap-2"><span class="text-cyan-300">→</span>Founders needing first campaign without ESP learning curve</li>
          <li class="flex gap-2"><span class="text-cyan-300">→</span>AI copy assist reduces blank-page paralysis</li>
          <li class="flex gap-2"><span class="text-cyan-300">→</span>Budget under $20/mo for email tooling</li>
        </ul>
      </div>
      <div class="card">
        <p class="badge">Who should skip</p>
        <ul class="mt-4 space-y-3 text-cyan-100">
          <li class="flex gap-2"><span class="text-cyan-300">→</span>150+ orders/mo — start Sequenzy or Omnisend</li>
          <li class="flex gap-2"><span class="text-cyan-300">→</span>Lifecycle revenue already strategic priority</li>
          <li class="flex gap-2"><span class="text-cyan-300">→</span>Need SMS, push, or multichannel day one</li>
          <li class="flex gap-2"><span class="text-cyan-300">→</span>Already on capable ESP — no downgrade</li>
        </ul>
      </div>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-white">tinyEmail to Sequenzy graduation checklist</h2>
      <p>
        Trigger migration when any two hit: 150+ orders/mo sustained, cart recovery unmeasured, winback manual or nonexistent, subscriber bill approaching Sequenzy send-equivalent cost, repeat purchase rate flat quarter over quarter.
      </p>
      <p>
        Export contacts with consent dates. Launch Sequenzy welcome first; pause tinyEmail automations before enabling cart to prevent duplicates. First month on Sequenzy: measure cart recovery with holdout — baseline tinyEmail never provided.
      </p>
      <p>
        Keep tinyEmail account one month parallel for broadcast transition if nervous — then cancel. Do not maintain dual automation stacks beyond overlap window.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-white">Real merchant stack patterns with tinyEmail</h2>
      <p>
        <strong>New candle shop:</strong> tinyEmail AI sale campaign live in 45 minutes — first BFCM participation without hiring freelancer. Graduation trigger documented at 150 orders/mo toward Sequenzy.
      </p>
      <p>
        <strong>Side-project apparel:</strong> Months 1–4 on tinyEmail adequate. Month 5 winback split attempt failed — Sequenzy migration in nine days with measurable cart holdout finally available.
      </p>
      <p>
        <strong>vs Shopify Email:</strong> Founders choosing between Admin-native Shopify Email and tinyEmail — pick tinyEmail when AI copy and basic automations matter; pick Shopify Email when absolute zero extra apps matters.
      </p>
    </div>

    <div class="card mb-12">
      <p class="badge">Compare alternatives</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-white">tinyEmail vs other Shopify starter options</h2>
      <ul class="mt-6 space-y-3 text-lg font-bold">
        <li><a class="link" href="/apps/shopify-email">Shopify Email review</a> — Admin-native zero friction</li>
        <li><a class="link" href="/compare/sequenzy-vs-shopify-email">Sequenzy vs Shopify Email</a> — lifecycle vs starter broadcast</li>
        <li><a class="link" href="/apps/sequenzy">Sequenzy review</a> — graduation destination</li>
        <li><a class="link" href="/compare/omnisend-vs-shopify-email">Omnisend vs Shopify Email</a> — multichannel upgrade path</li>
      </ul>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/apps">All Shopify SMS apps →</a>
      <a class="link" href="/apps/sequenzy">Sequenzy review →</a>
      <a class="link" href="/for/budget">Budget stores →</a>
    </div>
  </section>
    <div class="prose-shopify card mt-12">
      <h2>TCPA, consent, and cost-per-message discipline</h2>
      <p>SMS on Shopify is not a faster email channel. Every send needs express written consent, documented opt-in source, quiet-hour configuration, and a margin model that includes platform fees, carrier surcharges, and discount depth. Postscript, Attentive, and Omnisend SMS expose compliance tooling — but merchants still own consent copy at checkout, popups, and keyword campaigns.</p>
      <p>Model cost per delivered message before scaling broadcasts. A recovered cart that required 25% off plus three texts is often negative contribution margin even when attribution dashboards look green. Pair urgent SMS with Sequenzy email when the message needs education, social proof, or multi-product context — never duplicate the same offer on both channels within twenty-four hours unless the subscriber opted into high-frequency updates.</p>
      <p>Weekly ops: audit STOP/HELP handling, reply inbox backlog, opt-out spikes by flow, and suppression overlap with email cart recovery. Quarterly: re-read popup and checkout consent language against live automations. TCPA litigation and carrier filtering both punish stores that treat SMS like promotional email with shorter copy.</p>
    </div>



  <FaqSection faqs={faqs} title="tinyEmail Shopify FAQ" />
</BaseLayout>
